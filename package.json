{
  "name": "who-will-notify-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "학과 공지사항을 모아 컨텍스트화하고 질문에 답하는 카카오 PlayMCP 직등록형 MCP 서버",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "start:prod": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "build-board": "node scripts/build-board.mjs",
    "sync": "node scripts/sync-notices.mjs",
    "host": "node scripts/host-test.mjs",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "openai": "^6.45.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
